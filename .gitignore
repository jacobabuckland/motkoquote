# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# capacitor / ios native build artifacts
# The generated ios/ project (from `pnpm cap:add-ios`) is committed, but its
# CocoaPods and Xcode build output are not.
/ios/App/Pods/
/ios/App/App/public/
/ios/App/build/
/ios/DerivedData/
/ios/App/App/capacitor.config.json

# typescript
*.tsbuildinfo
next-env.d.ts
