# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public App Store listing for the landing-page download button. Set once the app
# has a numeric App Store ID (e.g. https://apps.apple.com/gb/app/motko/id0000000000).
# Unset falls back to an App Store search for "Motko".
NEXT_PUBLIC_APP_STORE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Whisper (OpenAI)
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (email)
RESEND_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Companies House API
COMPANIES_HOUSE_API_KEY=

# Google Maps Platform (address autocomplete — Places API New)
# Public (browser) key, restrict by HTTP referrer + Places API only. See README.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`.
# Public key is exposed to the browser to subscribe; private key stays server-side.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@motko.app

# Apple Push Notification service (native iOS app — token-based .p8 auth).
# APNS_PRIVATE_KEY holds the .p8 contents with newlines escaped as \n.
# APNS_ENV: "sandbox" for dev builds, "production" for App Store / TestFlight.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=app.motko.ios
APNS_ENV=sandbox

# Cron (protects /api/cron/* routes)
CRON_SECRET=
